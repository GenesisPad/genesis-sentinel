# Base path/URL of the Genesis Sentinel API. Defaults to the relative "/v1" path, which
# works in production because Nginx proxies /v1/* to the API on the same origin — no
# build-time value needs to be correct for prod. Only override for local dev against a
# separately-hosted API (e.g. http://localhost:4000/v1).
# NEXT_PUBLIC_API_BASE_URL=/v1

# Set to "true" to serve local fixtures instead of hitting the API (offline UI dev only).
NEXT_PUBLIC_USE_FIXTURES=false

# Public origin used for share links and SEO canonical URLs
NEXT_PUBLIC_SITE_URL=https://sentinel.genesispad.app
